Algoritmo Par_Impar
	//Definimos las variables
	Definir n1 Como Entero
	//Pedir el número
	Escribir 'Dame el valor que quieras saber si es par o impar'
	//Escribimos el número
	Leer n1
	//Hacer la operatoria
	SI n1%2=0 Entonces
		Escribir n1 ' es par'
		SINO Escribir n1 ' es impar'
	FinSi
	
FinAlgoritmo
