Algoritmo ConversorMillasMarinasAMetros
	//Definimos las variables
	Definir mm Como Entero
	definir conversión Como Real
	//Pedimos las millas marinas
	Escribir 'Dime cuántas millas marinas'
	//Escribimos las millas marinas
	Leer MM
	//Definimos cómo es la operación
	Conversión = MM * 1852
